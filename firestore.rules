rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default rule: Deny all reads, updates, and deletes by default
    // Only allow operations explicitly defined below
    match /{document=**} {
      allow read, update, delete: if false;
    }

    // Rules for the 'quotes' collection (from QuoteModal.jsx)
    match /quotes/{quoteId} {
      allow create: if 
        // Must contain basic fields to prevent spam
        request.resource.data.keys().hasAll(['name', 'contact', 'details', 'createdAt', 'source']) &&
        // Basic type validation
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() < 100 &&
        request.resource.data.details is string &&
        request.resource.data.details.size() < 5000;
    }

    // Rules for the 'contacts' collection (from Contact page)
    match /contacts/{contactId} {
      allow create: if 
        request.resource.data.keys().hasAll(['name', 'email', 'phone', 'description', 'createdAt']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() < 100 &&
        request.resource.data.description is string &&
        request.resource.data.description.size() < 5000;
    }

    // Rules for the 'teamApplications' collection (from Team page)
    match /teamApplications/{applicationId} {
      allow create: if 
        request.resource.data.keys().hasAll(['name', 'email', 'role', 'experience', 'createdAt']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() < 100 &&
        request.resource.data.experience is string &&
        request.resource.data.experience.size() < 5000;
    }
  }
}
